  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "indexnow": "node -e \"const k='8e87c3ef6a229adecc30897529af80dc';const u=Array.from((require('fs').readFileSync('build/sitemap.xml','utf8').matchAll(/<loc>([^<]+)<\\/loc>/g))).map(m=>m[1]);require('https').request({hostname:'api.indexnow.org',path:'/IndexNow',method:'POST',headers:{'Content-Type':'application/json'}},r=>{r.on('data',d=>process.stdout.write(d));r.on('end',()=>console.log('\\nindexnow status',r.statusCode))}).end(JSON.stringify({host:'smsapp-docs.aoneahsan.com',key:k,keyLocation:'https://smsapp-docs.aoneahsan.com/'+k+'.txt',urlList:u}))\""
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.2.17",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "yarn@4.14.1"
}
